{
  "name": "bystrov/abstract-shop",
  "description": "Abstract интернет-магазин: модели, CRUD, фасады курса валют и доставки (Laravel Package).",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": "^8.0",
    "illuminate/support": "^8.0",
    "illuminate/database": "^8.0",
    "illuminate/routing": "^8.0",
    "illuminate/view": "^8.0",
    "illuminate/http": "^8.0"
  },
  "require-dev": {
    "orchestra/testbench": "^6.0"
  },
  "autoload": {
    "psr-4": {
      "Bystrov\\AbstractShop\\": "src/",
      "Bystrov\\AbstractShop\\Database\\Factories\\": "src/Database/Factories/",
      "Bystrov\\AbstractShop\\Database\\Seeders\\": "src/Database/Seeders/"
    }
  },
  "autoload-dev": {
    "psr-4": {}
  },
  "extra": {
    "laravel": {
      "providers": [
        "Bystrov\\AbstractShop\\AbstractShopServiceProvider"
      ],
      "aliases": {
        "CurrencyRate": "Bystrov\\AbstractShop\\Facades\\CurrencyRate",
        "DeliveryCost": "Bystrov\\AbstractShop\\Facades\\DeliveryCost"
      }
    }
  },
  "config": {
    "audit": {
      "ignore": [
        "PKSA-8qx3-n5y5-vvnd",
        "PKSA-w7xr-vk7n-rstm"
      ]
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}

